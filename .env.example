# Required
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id

# Optional (defaults shown)
SUMMARY_TIME=07:00
SUMMARY_TZ=Europe/London
UPCOMING_DAYS=14
STADIUM_URL=https://www.london-stadium.com/events/all.html

# Comma-separated chat ids allowed to use commands. Blank = only TELEGRAM_CHAT_ID.
ALLOWED_CHAT_IDS=

# Bin collection reminder (optional). Leave BIN_COUNCIL blank to disable.
# BIN_COUNCIL must be a uk-bin-collection module for a London borough
# (see LONDON_BOROUGHS in src/assistant/sources/bins.py). Supply whichever
# identifier your borough needs: UPRN, or postcode (+ house number).
# A few boroughs need a remote Selenium driver via BIN_WEB_DRIVER.
BIN_COUNCIL=
BIN_COUNCIL_URL=
BIN_UPRN=
BIN_POSTCODE=
BIN_HOUSE_NUMBER=
BIN_WEB_DRIVER=
BIN_SKIP_GET_URL=true
BIN_REMINDER_TIME=20:00
